# WeFlow local HTTP API.
WEFLOW_BASE_URL=http://127.0.0.1:5031/api/v1
WEFLOW_TOKEN=替换成WeFlow设置页里的APIToken

# Local state/output directory.
WEFLOW_SYNC_DIR=/home/yangsan/weflow-hermes-sync/data

# AList/Quark rclone remote.
# Adjust /quark if your AList mount path is different.
WEFLOW_SYNC_REMOTE=quark-alist:/quark/WeFlow-Hermes
WEFLOW_SYNC_RCLONE_BIN=rclone

# direct is the default because Quark/AList remote move can be eventually consistent.
# Set to staging only if your remote supports reliable server-side move.
WEFLOW_SYNC_UPLOAD_MODE=direct

# First run pulls the last hour. Later runs start from state.lastSyncAt.
WEFLOW_SYNC_LOOKBACK_SECONDS=3600

# Add a small overlap to avoid missing delayed messages at hour boundaries.
WEFLOW_SYNC_OVERLAP_SECONDS=120

# WeFlow API limits.
WEFLOW_SYNC_SESSION_LIMIT=10000
WEFLOW_SYNC_MESSAGE_LIMIT=5000

# Optional: comma-separated session IDs. Leave empty to sync all recently active sessions.
# WEFLOW_SYNC_INCLUDE_SESSIONS=wxid_xxx,xxx@chatroom
